# Copy to .env.local for local dev. NEVER commit real secret values.
# On Netlify, set these in Site settings → Environment variables.

# ── Client (public by design — injected into the browser bundle) ──
VITE_SUPABASE_URL=https://ymplbgcuwgqjkxmfenwj.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
# Master switch. Leave false until Stripe is wired + tested; flip to true to launch.
VITE_PAYWALL_ENABLED=false

# ── Server only (Netlify Functions) — SECRET, never shipped to the browser ──
SUPABASE_URL=https://ymplbgcuwgqjkxmfenwj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
SITE_URL=https://quantinterview.netlify.app

# Stripe Price IDs (create the products in Stripe, paste the price_... ids here)
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_ANNUAL=price_xxx
STRIPE_PRICE_WEEK=price_xxx
STRIPE_PRICE_MONTH=price_xxx
